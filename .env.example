# LLM Provider: "openrouter" or "ollama"
PROVIDER=openrouter

# OpenRouter (when PROVIDER=openrouter)
OPENROUTER_API_KEY=your-openrouter-api-key-here
MODEL=anthropic/claude-sonnet-4

# Ollama (when PROVIDER=ollama)
# PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# MODEL=llama3.1

# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mentara

# Clerk Authentication
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# Data directory (legacy, for backward compat)
DATA_DIR=./data
